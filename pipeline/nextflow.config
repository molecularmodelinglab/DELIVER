/*
 * DELIVER Pipeline Configuration
 *
 * Usage:
 *   nextflow run pipeline/main.nf -profile longleaf -params-file params.yml
 *
 * Profiles:
 *   longleaf  — UNC Longleaf HPC (SLURM)
 *   local     — local execution (development)
 */

// ============================================================================
// PARAMETERS
// ============================================================================

params {
    // Required
    deli_dir        = null   // path to DELi repository — used by setup.sh only

    // Output
    out_dir         = null

    // Selection metadata (written into the generated decode.yaml)
    selection_id          = "selection"
    target_id             = "target"
    selection_condition   = "-"
    date_ran              = ""
    additional_info       = ""

    // FASTQ input files (for FULL and FROM_FASTQ)
    read_1         = null   // R1 files (list)
    read_2         = null   // R2 files (list), null = single-end

    // Libraries to decode against
    libraries             = []

    // Decode settings
    library_error_tolerance  = 2
    min_library_overlap      = 8
    revcomp                  = "YES"
    demultiplexer_algorithm  = "regex"
    demultiplexer_mode   = "single"
    realign                  = "NO"
    wiggle                   = "YES"

    // Preprocessing parameters
    fastp_threads   = 8    // increase for large files

    // DELi runtime parameters
    deli_data_dir   = null
    config_file     = null
    chunk_size      = 1000000
    prefix          = ""
    debug           = false

    // For FROM_COUNTS entry point
    counts_file     = null
}

// ============================================================================
// DEFAULT PROCESS SETTINGS
// ============================================================================

process {
    cpus   = 1
    memory = 4.GB

    withName: 'CollectDecodeChunks|CollectCountChunks' {
        memory = 16.GB
    }
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {

    // UNC LONGLEAF (SLURM)
    longleaf {

        process {
            executor     = 'slurm'
            errorStrategy = 'retry'
            maxRetries   = 2

            // Default for small tasks
            cpus   = 1
            memory = 8.GB
            time   = '30m'

            withName: 'GenerateDecodeYaml' {
                memory = 256.MB
                time   = '2m'
            }

            withName: 'CONCAT' {
                cpus   = 1
                memory = 5.GB
                time   = '1h'
            }

            withName: 'FASTP_MERGE' {
                module = 'fastp/1.0.1'
                cpus   = 8
                memory = 40.GB
                time   = '4h'
                clusterOptions = '--ntasks=1 --cpus-per-task=8'
            }

            withName: 'DECOMPRESS' {
                cpus   = 1
                memory = 4.GB
                time   = '1h'
            }

            withName: 'ExtractSequenceFiles' {
                memory = 256.MB
                time   = '2m'
            }

            withName: 'DecodeChunk' {
                memory = 4.GB
                time   = '15m'
            }

            withName: 'CountChunk' {
                memory = 2.GB
                time   = '10m'
            }

            // High-memory aggregation steps
            withName: 'CollectDecodeChunks|CollectCountChunks' {
                cpus   = 2
                memory = 128.GB
                time   = '2h'
            }

            withName: 'MergeDecodeStatistics|SummarizeDecodeRun' {
                memory = 4.GB
                time   = '20m'
            }

            withName: 'WriteDecodeReport' {
                memory = 4.GB
                time   = '10m'
            }
        }

        executor {
            queueSize       = 50
            submitRateLimit = '10 sec'
            exitReadTimeout = '15 min'
        }
    }

    // LOCAL EXECUTION (Development)
    local {
        process {
            executor = 'local'
            cpus     = 1

            withName: 'CollectDecodeChunks|CollectCountChunks' {
                memory = 16.GB
            }
        }
    }

}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name        = 'DELIVER'
    description = 'DEL pipeline orchestration'
    version     = '0.1.0'
    mainScript  = 'pipeline/main.nf'
}
